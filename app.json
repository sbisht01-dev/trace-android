{
  "expo": {
    "name": "trace-android",
    "slug": "trace-android",
    "version": "1.1.0",
    "android": {
      "package": "com.watcher_01.traceandroid",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDQGs2yQ86yi3abXdWO_38i3lDQbkztoVI"
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Trace to use your location to record your walks.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "foregroundService": {
            "notificationTitle": "Trace is active",
            "notificationBody": "Recording your path in the background...",
            "notificationColor": "#0F172A",
            "foregroundServiceType": "location"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "83b38256-4700-4ea4-8fd9-5ce308606737"
      }
    }
  }
}